---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---
<Base activeNav="home">
  <section class="hero">
    <div class="over caps">✦ Now taking table space ✦</div>
    <h2 class="slab">Games worth <span class="out">printing</span></h2>
    <p>Reviews that age well. Designs straight off my workbench.</p>
    <div class="orn">❦</div>
  </section>

  <section class="wrap">
    <div class="sec-title">
      <h3 class="slab">Fresh off the press</h3>
      <div class="fill"></div>
    </div>
    <div class="posts">
      {posts.map((post) => (
        <PostCard
          url={`/blog/${post.id}`}
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          category={post.data.category}
        />
      ))}
    </div>
  </section>

  <Newsletter />
</Base>
